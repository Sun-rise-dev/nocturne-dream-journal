# Nocturne — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Image generation API (server-side only, never exposed to client)
# Supported provider: https://shiyunapi.com
IMAGE_API_BASE=https://shiyunapi.com
IMAGE_API_KEY=sk-your-key-here
IMAGE_MODEL=gemini-3.1-flash-image-preview

# Flask configuration
FLASK_DEBUG=0
# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change-me-to-a-random-secret

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:12450,http://127.0.0.1:12450,https://sun-rise-dev.github.io
